# HammerTimeBet — Vercel Environment Variables
# Copy these into Vercel → Project Settings → Environment Variables
# Never commit real values to this file.

# Required — get a free key at https://the-odds-api.com (500 req/month free)
ODDS_API_KEY=your_odds_api_key_here

# Optional — which bookmaker's lines to pull (default: draftkings)
# Other options: fanduel, betmgm, pointsbet, bovada, etc.
ODDS_BOOKMAKER=draftkings
